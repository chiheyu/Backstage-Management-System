<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.app.mapper.AppUserMapper">

    <resultMap type="AppUser" id="AppUserResult">
        <id property="appUserId" column="app_user_id"/>
        <result property="sysUserId" column="sys_user_id"/>
        <result property="phone" column="phone"/>
        <result property="nickName" column="nick_name"/>
        <result property="roleType" column="role_type"/>
        <result property="merchantId" column="merchant_id"/>
        <result property="status" column="status"/>
        <result property="lastSmsCode" column="last_sms_code"/>
        <result property="lastSmsExpireTime" column="last_sms_expire_time"/>
        <result property="userName" column="user_name"/>
        <result property="merchantName" column="merchant_name"/>
        <result property="createBy" column="create_by"/>
        <result property="createTime" column="create_time"/>
        <result property="updateBy" column="update_by"/>
        <result property="updateTime" column="update_time"/>
        <result property="remark" column="remark"/>
    </resultMap>

    <sql id="selectAppUserVo">
        select au.app_user_id, au.sys_user_id, au.phone, au.nick_name, au.role_type, au.merchant_id,
               au.status, au.last_sms_code, au.last_sms_expire_time, au.create_by, au.create_time,
               au.update_by, au.update_time, au.remark, su.user_name, am.merchant_name
        from app_user au
        left join sys_user su on su.user_id = au.sys_user_id
        left join app_merchant am on am.merchant_id = au.merchant_id
    </sql>

    <select id="selectAppUserById" parameterType="Long" resultMap="AppUserResult">
        <include refid="selectAppUserVo"/>
        where au.app_user_id = #{appUserId}
    </select>

    <select id="selectAppUserBySysUserId" parameterType="Long" resultMap="AppUserResult">
        <include refid="selectAppUserVo"/>
        where au.sys_user_id = #{sysUserId}
    </select>

    <select id="selectAppUserByPhone" parameterType="String" resultMap="AppUserResult">
        <include refid="selectAppUserVo"/>
        where au.phone = #{phone}
    </select>

    <select id="selectAppUserList" parameterType="AppUser" resultMap="AppUserResult">
        <include refid="selectAppUserVo"/>
        <where>
            <if test="phone != null and phone != ''">
                and au.phone like concat('%', #{phone}, '%')
            </if>
            <if test="nickName != null and nickName != ''">
                and au.nick_name like concat('%', #{nickName}, '%')
            </if>
            <if test="roleType != null and roleType != ''">
                and au.role_type = #{roleType}
            </if>
            <if test="status != null and status != ''">
                and au.status = #{status}
            </if>
            <if test="merchantId != null">
                and au.merchant_id = #{merchantId}
            </if>
        </where>
        order by au.app_user_id desc
    </select>

    <insert id="insertAppUser" parameterType="AppUser" useGeneratedKeys="true" keyProperty="appUserId">
        insert into app_user
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="sysUserId != null">sys_user_id,</if>
            <if test="phone != null and phone != ''">phone,</if>
            <if test="nickName != null and nickName != ''">nick_name,</if>
            <if test="roleType != null and roleType != ''">role_type,</if>
            <if test="merchantId != null">merchant_id,</if>
            <if test="status != null and status != ''">status,</if>
            <if test="lastSmsCode != null and lastSmsCode != ''">last_sms_code,</if>
            <if test="lastSmsExpireTime != null">last_sms_expire_time,</if>
            <if test="createBy != null and createBy != ''">create_by,</if>
            create_time,
            remark
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="sysUserId != null">#{sysUserId},</if>
            <if test="phone != null and phone != ''">#{phone},</if>
            <if test="nickName != null and nickName != ''">#{nickName},</if>
            <if test="roleType != null and roleType != ''">#{roleType},</if>
            <if test="merchantId != null">#{merchantId},</if>
            <if test="status != null and status != ''">#{status},</if>
            <if test="lastSmsCode != null and lastSmsCode != ''">#{lastSmsCode},</if>
            <if test="lastSmsExpireTime != null">#{lastSmsExpireTime},</if>
            <if test="createBy != null and createBy != ''">#{createBy},</if>
            sysdate(),
            #{remark}
        </trim>
    </insert>

    <update id="updateAppUser" parameterType="AppUser">
        update app_user
        <set>
            <if test="sysUserId != null">sys_user_id = #{sysUserId},</if>
            <if test="phone != null and phone != ''">phone = #{phone},</if>
            <if test="nickName != null and nickName != ''">nick_name = #{nickName},</if>
            <if test="roleType != null and roleType != ''">role_type = #{roleType},</if>
            <if test="merchantId != null">merchant_id = #{merchantId},</if>
            <if test="status != null and status != ''">status = #{status},</if>
            <if test="lastSmsCode != null">last_sms_code = #{lastSmsCode},</if>
            <if test="lastSmsExpireTime != null">last_sms_expire_time = #{lastSmsExpireTime},</if>
            <if test="updateBy != null and updateBy != ''">update_by = #{updateBy},</if>
            <if test="remark != null">remark = #{remark},</if>
            update_time = sysdate()
        </set>
        where app_user_id = #{appUserId}
    </update>

    <delete id="deleteAppUserById" parameterType="Long">
        delete from app_user where app_user_id = #{appUserId}
    </delete>
</mapper>
