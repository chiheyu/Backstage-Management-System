<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.app.mapper.AppAccessoryMapper">

    <resultMap type="AppAccessory" id="AppAccessoryResult">
        <id property="accessoryId" column="accessory_id"/>
        <result property="categoryName" column="category_name"/>
        <result property="accessoryName" column="accessory_name"/>
        <result property="accessoryDesc" column="accessory_desc"/>
        <result property="merchantId" column="merchant_id"/>
        <result property="coverImage" column="cover_image"/>
        <result property="price" column="price"/>
        <result property="stock" column="stock"/>
        <result property="salesCount" column="sales_count"/>
        <result property="status" column="status"/>
        <result property="collected" column="collected"/>
        <result property="createBy" column="create_by"/>
        <result property="createTime" column="create_time"/>
        <result property="updateBy" column="update_by"/>
        <result property="updateTime" column="update_time"/>
        <result property="remark" column="remark"/>
    </resultMap>

    <sql id="selectAccessoryBaseVo">
        select aa.accessory_id, aa.category_name, aa.accessory_name, aa.accessory_desc, aa.merchant_id, aa.cover_image,
               aa.price, aa.stock, aa.sales_count, aa.status, aa.create_by, aa.create_time,
               aa.update_by, aa.update_time, aa.remark, false as collected
        from app_accessory aa
    </sql>

    <sql id="selectAccessoryVo">
        select aa.accessory_id, aa.category_name, aa.accessory_name, aa.accessory_desc, aa.merchant_id, aa.cover_image,
               aa.price, aa.stock, aa.sales_count, aa.status, aa.create_by, aa.create_time,
               aa.update_by, aa.update_time, aa.remark,
               <choose>
                   <when test="params != null and params.appUserId != null">
                       if(ac.collection_id is null, false, true) as collected
                   </when>
                   <otherwise>
                       false as collected
                   </otherwise>
               </choose>
        from app_accessory aa
        <if test="params != null and params.appUserId != null">
            left join app_accessory_collection ac
                on ac.accessory_id = aa.accessory_id and ac.app_user_id = #{params.appUserId}
        </if>
    </sql>

    <select id="selectAccessoryById" parameterType="Long" resultMap="AppAccessoryResult">
        <include refid="selectAccessoryBaseVo"/>
        where aa.accessory_id = #{accessoryId}
    </select>

    <select id="selectAccessoryList" parameterType="AppAccessory" resultMap="AppAccessoryResult">
        <include refid="selectAccessoryVo"/>
        <where>
            <if test="categoryName != null and categoryName != ''">
                and aa.category_name = #{categoryName}
            </if>
            <if test="accessoryName != null and accessoryName != ''">
                and aa.accessory_name like concat('%', #{accessoryName}, '%')
            </if>
            <if test="status != null and status != ''">
                and aa.status = #{status}
            </if>
            <if test="merchantId != null">
                and aa.merchant_id = #{merchantId}
            </if>
            <if test="params != null and params.beginPrice != null and params.beginPrice != ''">
                and aa.price &gt;= #{params.beginPrice}
            </if>
            <if test="params != null and params.endPrice != null and params.endPrice != ''">
                and aa.price &lt;= #{params.endPrice}
            </if>
        </where>
        order by aa.accessory_id desc
    </select>

    <insert id="insertAccessory" parameterType="AppAccessory" useGeneratedKeys="true" keyProperty="accessoryId">
        insert into app_accessory
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="categoryName != null and categoryName != ''">category_name,</if>
            <if test="accessoryName != null and accessoryName != ''">accessory_name,</if>
            <if test="accessoryDesc != null">accessory_desc,</if>
            <if test="merchantId != null">merchant_id,</if>
            <if test="coverImage != null">cover_image,</if>
            <if test="price != null">price,</if>
            <if test="stock != null">stock,</if>
            <if test="salesCount != null">sales_count,</if>
            <if test="status != null and status != ''">status,</if>
            <if test="createBy != null and createBy != ''">create_by,</if>
            create_time,
            remark
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="categoryName != null and categoryName != ''">#{categoryName},</if>
            <if test="accessoryName != null and accessoryName != ''">#{accessoryName},</if>
            <if test="accessoryDesc != null">#{accessoryDesc},</if>
            <if test="merchantId != null">#{merchantId},</if>
            <if test="coverImage != null">#{coverImage},</if>
            <if test="price != null">#{price},</if>
            <if test="stock != null">#{stock},</if>
            <if test="salesCount != null">#{salesCount},</if>
            <if test="status != null and status != ''">#{status},</if>
            <if test="createBy != null and createBy != ''">#{createBy},</if>
            sysdate(),
            #{remark}
        </trim>
    </insert>

    <update id="updateAccessory" parameterType="AppAccessory">
        update app_accessory
        <set>
            <if test="categoryName != null and categoryName != ''">category_name = #{categoryName},</if>
            <if test="accessoryName != null and accessoryName != ''">accessory_name = #{accessoryName},</if>
            <if test="accessoryDesc != null">accessory_desc = #{accessoryDesc},</if>
            <if test="merchantId != null">merchant_id = #{merchantId},</if>
            <if test="coverImage != null">cover_image = #{coverImage},</if>
            <if test="price != null">price = #{price},</if>
            <if test="stock != null">stock = #{stock},</if>
            <if test="salesCount != null">sales_count = #{salesCount},</if>
            <if test="status != null and status != ''">status = #{status},</if>
            <if test="updateBy != null and updateBy != ''">update_by = #{updateBy},</if>
            <if test="remark != null">remark = #{remark},</if>
            update_time = sysdate()
        </set>
        where accessory_id = #{accessoryId}
    </update>

    <delete id="deleteAccessoryById" parameterType="Long">
        delete from app_accessory where accessory_id = #{accessoryId}
    </delete>
</mapper>
