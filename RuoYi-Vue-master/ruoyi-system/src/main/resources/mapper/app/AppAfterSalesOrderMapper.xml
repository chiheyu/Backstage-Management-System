<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.app.mapper.AppAfterSalesOrderMapper">

    <resultMap type="AppAfterSalesOrder" id="AppAfterSalesOrderResult">
        <id property="orderId" column="order_id"/>
        <result property="orderNo" column="order_no"/>
        <result property="appUserId" column="app_user_id"/>
        <result property="merchantId" column="merchant_id"/>
        <result property="productType" column="product_type"/>
        <result property="faultDesc" column="fault_desc"/>
        <result property="faultImages" column="fault_images"/>
        <result property="status" column="status"/>
        <result property="serviceRemark" column="service_remark"/>
        <result property="contactName" column="contact_name"/>
        <result property="contactPhone" column="contact_phone"/>
        <result property="address" column="address"/>
        <result property="acceptTime" column="accept_time"/>
        <result property="finishTime" column="finish_time"/>
        <result property="userName" column="user_name"/>
        <result property="merchantName" column="merchant_name"/>
        <result property="createBy" column="create_by"/>
        <result property="createTime" column="create_time"/>
        <result property="updateBy" column="update_by"/>
        <result property="updateTime" column="update_time"/>
        <result property="remark" column="remark"/>
    </resultMap>

    <sql id="selectAfterSalesOrderVo">
        select aso.order_id, aso.order_no, aso.app_user_id, aso.merchant_id, aso.product_type,
               aso.fault_desc, aso.fault_images, aso.status, aso.service_remark, aso.contact_name,
               aso.contact_phone, aso.address, aso.accept_time, aso.finish_time, aso.create_by,
               aso.create_time, aso.update_by, aso.update_time, aso.remark, au.nick_name as user_name,
               am.merchant_name
        from app_after_sales_order aso
        left join app_user au on au.app_user_id = aso.app_user_id
        left join app_merchant am on am.merchant_id = aso.merchant_id
    </sql>

    <select id="selectAfterSalesOrderById" parameterType="Long" resultMap="AppAfterSalesOrderResult">
        <include refid="selectAfterSalesOrderVo"/>
        where aso.order_id = #{orderId}
    </select>

    <select id="selectAfterSalesOrderList" parameterType="AppAfterSalesOrder" resultMap="AppAfterSalesOrderResult">
        <include refid="selectAfterSalesOrderVo"/>
        <where>
            <if test="orderNo != null and orderNo != ''">
                and aso.order_no like concat('%', #{orderNo}, '%')
            </if>
            <if test="appUserId != null">
                and aso.app_user_id = #{appUserId}
            </if>
            <if test="merchantId != null">
                and aso.merchant_id = #{merchantId}
            </if>
            <if test="status != null and status != ''">
                and aso.status = #{status}
            </if>
            <if test="productType != null and productType != ''">
                and aso.product_type like concat('%', #{productType}, '%')
            </if>
            <if test="userName != null and userName != ''">
                and au.nick_name like concat('%', #{userName}, '%')
            </if>
            <if test="merchantName != null and merchantName != ''">
                and am.merchant_name like concat('%', #{merchantName}, '%')
            </if>
            <if test="params != null and params.beginTime != null and params.beginTime != ''">
                and date_format(aso.create_time,'%Y%m%d') &gt;= date_format(#{params.beginTime},'%Y%m%d')
            </if>
            <if test="params != null and params.endTime != null and params.endTime != ''">
                and date_format(aso.create_time,'%Y%m%d') &lt;= date_format(#{params.endTime},'%Y%m%d')
            </if>
        </where>
        order by aso.order_id desc
    </select>

    <insert id="insertAfterSalesOrder" parameterType="AppAfterSalesOrder" useGeneratedKeys="true" keyProperty="orderId">
        insert into app_after_sales_order
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="orderNo != null and orderNo != ''">order_no,</if>
            <if test="appUserId != null">app_user_id,</if>
            <if test="merchantId != null">merchant_id,</if>
            <if test="productType != null and productType != ''">product_type,</if>
            <if test="faultDesc != null and faultDesc != ''">fault_desc,</if>
            <if test="faultImages != null">fault_images,</if>
            <if test="status != null and status != ''">status,</if>
            <if test="serviceRemark != null">service_remark,</if>
            <if test="contactName != null and contactName != ''">contact_name,</if>
            <if test="contactPhone != null and contactPhone != ''">contact_phone,</if>
            <if test="address != null and address != ''">address,</if>
            <if test="acceptTime != null">accept_time,</if>
            <if test="finishTime != null">finish_time,</if>
            <if test="createBy != null and createBy != ''">create_by,</if>
            create_time,
            remark
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="orderNo != null and orderNo != ''">#{orderNo},</if>
            <if test="appUserId != null">#{appUserId},</if>
            <if test="merchantId != null">#{merchantId},</if>
            <if test="productType != null and productType != ''">#{productType},</if>
            <if test="faultDesc != null and faultDesc != ''">#{faultDesc},</if>
            <if test="faultImages != null">#{faultImages},</if>
            <if test="status != null and status != ''">#{status},</if>
            <if test="serviceRemark != null">#{serviceRemark},</if>
            <if test="contactName != null and contactName != ''">#{contactName},</if>
            <if test="contactPhone != null and contactPhone != ''">#{contactPhone},</if>
            <if test="address != null and address != ''">#{address},</if>
            <if test="acceptTime != null">#{acceptTime},</if>
            <if test="finishTime != null">#{finishTime},</if>
            <if test="createBy != null and createBy != ''">#{createBy},</if>
            sysdate(),
            #{remark}
        </trim>
    </insert>

    <update id="updateAfterSalesOrder" parameterType="AppAfterSalesOrder">
        update app_after_sales_order
        <set>
            <if test="orderNo != null and orderNo != ''">order_no = #{orderNo},</if>
            <if test="appUserId != null">app_user_id = #{appUserId},</if>
            <if test="merchantId != null">merchant_id = #{merchantId},</if>
            <if test="productType != null and productType != ''">product_type = #{productType},</if>
            <if test="faultDesc != null">fault_desc = #{faultDesc},</if>
            <if test="faultImages != null">fault_images = #{faultImages},</if>
            <if test="status != null and status != ''">status = #{status},</if>
            <if test="serviceRemark != null">service_remark = #{serviceRemark},</if>
            <if test="contactName != null and contactName != ''">contact_name = #{contactName},</if>
            <if test="contactPhone != null and contactPhone != ''">contact_phone = #{contactPhone},</if>
            <if test="address != null and address != ''">address = #{address},</if>
            <if test="acceptTime != null">accept_time = #{acceptTime},</if>
            <if test="finishTime != null">finish_time = #{finishTime},</if>
            <if test="updateBy != null and updateBy != ''">update_by = #{updateBy},</if>
            <if test="remark != null">remark = #{remark},</if>
            update_time = sysdate()
        </set>
        where order_id = #{orderId}
    </update>

    <delete id="deleteAfterSalesOrderById" parameterType="Long">
        delete from app_after_sales_order where order_id = #{orderId}
    </delete>
</mapper>
